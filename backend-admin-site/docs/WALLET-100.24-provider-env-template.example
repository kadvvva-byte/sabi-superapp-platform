# WALLET-100.24 Provider Environment Template
# Do not put these secrets in mobile.
# Use backend .env or secret vault references only.

# Admin
WALLET_PROVIDER_ADMIN_TOKEN=
SABI_ADMIN_API_TOKEN=

# Global execution switch. Keep false until real providers are connected.
WALLET_PROVIDER_EXECUTION_ENABLED=false

# Alipay+
WALLET_PROVIDER_ALIPAY_PLUS_ACQUIRING_ENABLED=false
WALLET_PROVIDER_ALIPAY_PLUS_ACQUIRING_CLIENT_ID=
WALLET_PROVIDER_ALIPAY_PLUS_ACQUIRING_SECRET_REF=
WALLET_PROVIDER_ALIPAY_PLUS_ACQUIRING_WEBHOOK_SECRET_REF=
WALLET_PROVIDER_ALIPAY_PLUS_ACQUIRING_WEBHOOK_URL=
WALLET_PROVIDER_EXECUTION_ALIPAY_PLUS_ACQUIRING_ENABLED=false

# Local bank gateway
WALLET_PROVIDER_LOCAL_BANK_GATEWAY_ENABLED=false
WALLET_PROVIDER_LOCAL_BANK_GATEWAY_CLIENT_ID=
WALLET_PROVIDER_LOCAL_BANK_GATEWAY_SECRET_REF=
