# WALLET-100.32 Bank/Card provider env template
# Values must live only in backend env/vault, never in mobile.

# Global execution remains disabled until real provider binding is reviewed.
WALLET_PROVIDER_EXECUTION_ENABLED=false

# Card tokenization
WALLET_PROVIDER_BANK_CARD_TOKENIZATION_ENABLED=false
WALLET_PROVIDER_BANK_CARD_TOKENIZATION_BASE_URL=
WALLET_PROVIDER_BANK_CARD_TOKENIZATION_CLIENT_ID=
WALLET_PROVIDER_BANK_CARD_TOKENIZATION_SECRET_VAULT_REF=
WALLET_PROVIDER_BANK_CARD_TOKENIZATION_WEBHOOK_SECRET_VAULT_REF=
WALLET_PROVIDER_BANK_CARD_TOKENIZATION_IFRAME_OR_SDK_ID=
WALLET_PROVIDER_BANK_CARD_TOKENIZATION_WEBHOOK_URL=/api/wallet/provider-webhooks/card-tokenization

# Local bank gateway
WALLET_PROVIDER_LOCAL_BANK_GATEWAY_ENABLED=false
WALLET_PROVIDER_LOCAL_BANK_GATEWAY_BASE_URL=
WALLET_PROVIDER_LOCAL_BANK_GATEWAY_MERCHANT_ID=
WALLET_PROVIDER_LOCAL_BANK_GATEWAY_SECRET_VAULT_REF=
WALLET_PROVIDER_LOCAL_BANK_GATEWAY_WEBHOOK_SECRET_VAULT_REF=
WALLET_PROVIDER_LOCAL_BANK_GATEWAY_WEBHOOK_URL=/api/wallet/provider-webhooks/local-bank

# Virtual card issuer
WALLET_PROVIDER_VIRTUAL_CARD_ISSUER_ENABLED=false
WALLET_PROVIDER_VIRTUAL_CARD_ISSUER_BASE_URL=
WALLET_PROVIDER_VIRTUAL_CARD_ISSUER_CLIENT_ID=
WALLET_PROVIDER_VIRTUAL_CARD_ISSUER_SECRET_VAULT_REF=
WALLET_PROVIDER_VIRTUAL_CARD_ISSUER_WEBHOOK_SECRET_VAULT_REF=
WALLET_PROVIDER_VIRTUAL_CARD_ISSUER_WEBHOOK_URL=/api/wallet/provider-webhooks/virtual-card-issuer
