# WALLET-100.39 — Alipay+/Merchant/Business env template
# Values must be stored only on backend/vault. Never place them in mobile.

# Alipay+
WALLET_PROVIDER_ALIPAY_PLUS_ACQUIRING_ENABLED=false
WALLET_PROVIDER_ALIPAY_PLUS_ACQUIRING_API_BASE_URL=
WALLET_PROVIDER_ALIPAY_PLUS_ACQUIRING_CLIENT_ID=
WALLET_PROVIDER_ALIPAY_PLUS_ACQUIRING_PRIVATE_KEY_VAULT_REF=
WALLET_PROVIDER_ALIPAY_PLUS_ACQUIRING_PUBLIC_KEY_VAULT_REF=
WALLET_PROVIDER_ALIPAY_PLUS_ACQUIRING_WEBHOOK_SECRET_VAULT_REF=
WALLET_PROVIDER_ALIPAY_PLUS_ACQUIRING_WEBHOOK_URL=/api/payment/provider-webhook/alipay-plus

# Merchant acquiring
WALLET_PROVIDER_MERCHANT_ACQUIRING_ENABLED=false
WALLET_PROVIDER_MERCHANT_ACQUIRING_API_BASE_URL=
WALLET_PROVIDER_MERCHANT_ACQUIRING_CLIENT_ID=
WALLET_PROVIDER_MERCHANT_ACQUIRING_API_KEY_VAULT_REF=
WALLET_PROVIDER_MERCHANT_ACQUIRING_WEBHOOK_SECRET_VAULT_REF=
WALLET_PROVIDER_MERCHANT_ACQUIRING_WEBHOOK_URL=/api/payment/provider-webhook/merchant-acquiring

# Business payout
WALLET_PROVIDER_BUSINESS_PAYOUT_ENABLED=false
WALLET_PROVIDER_BUSINESS_PAYOUT_API_BASE_URL=
WALLET_PROVIDER_BUSINESS_PAYOUT_CLIENT_ID=
WALLET_PROVIDER_BUSINESS_PAYOUT_API_KEY_VAULT_REF=
WALLET_PROVIDER_BUSINESS_PAYOUT_WEBHOOK_SECRET_VAULT_REF=
WALLET_PROVIDER_BUSINESS_PAYOUT_WEBHOOK_URL=/api/payment/provider-webhook/business-payout

# Execution remains false until real adapters are connected and verified.
WALLET_PROVIDER_EXECUTION_ALIPAY_PLUS_ACQUIRING_ENABLED=false
WALLET_PROVIDER_EXECUTION_MERCHANT_ACQUIRING_ENABLED=false
WALLET_PROVIDER_EXECUTION_BUSINESS_PAYOUT_ENABLED=false
