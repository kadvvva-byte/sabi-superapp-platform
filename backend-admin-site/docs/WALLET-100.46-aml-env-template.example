# WALLET-100.46 AML env template example

# Do not put real secrets into mobile.
# Real values must live only in backend env/vault.

WALLET_PROVIDER_AML_PROVIDER_ENABLED=false
WALLET_PROVIDER_AML_PROVIDER_ID=aml_provider
WALLET_PROVIDER_AML_PROVIDER_ENV=sandbox
WALLET_PROVIDER_AML_PROVIDER_API_BASE_URL=
WALLET_PROVIDER_AML_PROVIDER_API_KEY_VAULT_REF=
WALLET_PROVIDER_AML_PROVIDER_WEBHOOK_SECRET_VAULT_REF=
WALLET_PROVIDER_AML_PROVIDER_WEBHOOK_PATH=/api/wallet/provider-webhooks/aml
WALLET_PROVIDER_EXECUTION_AML_PROVIDER_ENABLED=false
