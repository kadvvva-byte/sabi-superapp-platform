# WALLET-100.50 bank/card/issuer safe-disabled sandbox skeleton
# Replace provider.example.invalid and vault refs only after real bank/provider contract exists.
# Keep all ENABLED/execution flags false until real adapter binding is complete.

WALLET_PROVIDER_BANK_CARD_TOKENIZATION_ENABLED=false
WALLET_PROVIDER_BANK_CARD_TOKENIZATION_ID=bank_card_tokenization_sandbox_disabled
WALLET_PROVIDER_BANK_CARD_TOKENIZATION_BASE_URL=https://provider.example.invalid/card-tokenization/sandbox
WALLET_PROVIDER_BANK_CARD_TOKENIZATION_API_KEY_VAULT_REF=vault://wallet/sandbox/bank_card_tokenization/api_key
WALLET_PROVIDER_BANK_CARD_TOKENIZATION_WEBHOOK_SECRET_VAULT_REF=vault://wallet/sandbox/bank_card_tokenization/webhook_secret
WALLET_PROVIDER_BANK_CARD_TOKENIZATION_WEBHOOK_URL=http://localhost:4001/api/wallet/provider-webhooks/bank-card-tokenization
WALLET_PROVIDER_EXECUTION_BANK_CARD_TOKENIZATION_ENABLED=false
WALLET_PROVIDER_EXECUTION_CARD_TOKENIZATION_ENABLED=false

WALLET_PROVIDER_LOCAL_BANK_GATEWAY_ENABLED=false
WALLET_PROVIDER_LOCAL_BANK_GATEWAY_ID=local_bank_gateway_sandbox_disabled
WALLET_PROVIDER_LOCAL_BANK_GATEWAY_BASE_URL=https://provider.example.invalid/local-bank/sandbox
WALLET_PROVIDER_LOCAL_BANK_GATEWAY_API_KEY_VAULT_REF=vault://wallet/sandbox/local_bank_gateway/api_key
WALLET_PROVIDER_LOCAL_BANK_GATEWAY_WEBHOOK_SECRET_VAULT_REF=vault://wallet/sandbox/local_bank_gateway/webhook_secret
WALLET_PROVIDER_LOCAL_BANK_GATEWAY_WEBHOOK_URL=http://localhost:4001/api/wallet/provider-webhooks/local-bank-gateway
WALLET_PROVIDER_EXECUTION_LOCAL_BANK_GATEWAY_ENABLED=false
WALLET_PROVIDER_EXECUTION_WALLET_TRANSFER_ENABLED=false

WALLET_PROVIDER_VIRTUAL_CARD_ISSUER_ENABLED=false
WALLET_PROVIDER_VIRTUAL_CARD_ISSUER_ID=virtual_card_issuer_sandbox_disabled
WALLET_PROVIDER_VIRTUAL_CARD_ISSUER_BASE_URL=https://provider.example.invalid/virtual-card-issuer/sandbox
WALLET_PROVIDER_VIRTUAL_CARD_ISSUER_API_KEY_VAULT_REF=vault://wallet/sandbox/virtual_card_issuer/api_key
WALLET_PROVIDER_VIRTUAL_CARD_ISSUER_WEBHOOK_SECRET_VAULT_REF=vault://wallet/sandbox/virtual_card_issuer/webhook_secret
WALLET_PROVIDER_VIRTUAL_CARD_ISSUER_WEBHOOK_URL=http://localhost:4001/api/wallet/provider-webhooks/virtual-card-issuer
WALLET_PROVIDER_EXECUTION_VIRTUAL_CARD_ISSUER_ENABLED=false
WALLET_PROVIDER_EXECUTION_VIRTUAL_CARD_ISSUE_ENABLED=false
