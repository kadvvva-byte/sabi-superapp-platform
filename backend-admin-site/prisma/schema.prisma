generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// USERS
//////////////////////////////////////////////////////

model User {
  id String @id @default(uuid())

  email    String  @unique
  phone    String? @unique
  username String? @unique
  password String

  displayName     String  @default("")
  avatarUrl       String?
  bio             String?
  isPublicProfile Boolean @default(true)

  role Role

  pushToken String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  messages     Message[]
  reactions    MessageReaction[]
  stories      Story[]
  tokens       RefreshToken[]
  authAccounts AuthAccount[]

  wallets Wallet[]
  qrs     Qr[]

  businessWallets BusinessWallet[] @relation("BusinessWalletOwner")
  merchantWallets MerchantWallet[] @relation("MerchantWalletOwner")

  sentP2PTransfers     P2PTransfer[] @relation("P2PTransferSender")
  receivedP2PTransfers P2PTransfer[] @relation("P2PTransferRecipient")

  coinDeposits       CoinDeposit[]
  coinCreditRequests CoinCreditRequest[]
  walletOperations   WalletOperation[] @relation("WalletOperationOwner")

  chats ChatMember[]

  payments Payment[]

  presences               Presence?
  Product                 Product[]
  Order                   Order[]
  AIConversation          AIConversation[]
  aiSessions              AISession[]
  aiConsent               AIConsent?
  aiConsentEvents         AIConsentEvent[]
  aiMemoryEntries         AIMemoryEntry[]
  aiWorkspaceConnections  AIWorkspaceConnection[]
  aiTasks                 AITask[]
  aiUsageEvents           AIUsageEvent[]

  initiatedSabiCallSessions SabiCallSession[]     @relation("SabiCallSessionInitiator")
  sabiCallParticipations    SabiCallParticipant[] @relation("SabiCallParticipantUser")
}

enum Role {
  USER
  ADMIN
}

//////////////////////////////////////////////////////
// AUTH
//////////////////////////////////////////////////////

model RefreshToken {
  id String @id @default(uuid())

  tokenHash String @unique

  userId String

  expiresAt DateTime

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model AuthAccount {
  id String @id @default(uuid())

  userId String?

  email    String? @unique
  phone    String? @unique
  username String? @unique

  passwordHash String
  passwordSalt String?

  provider          String  @default("local")
  providerAccountId String?

  status String @default("active")

  emailVerified Boolean @default(false)
  phoneVerified Boolean @default(false)

  lastLoginAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([provider])
}

//////////////////////////////////////////////////////
// CHAT SYSTEM
//////////////////////////////////////////////////////

model Chat {
  id String @id @default(uuid())

  type ChatType

  title     String?
  avatarUrl String?

  createdBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members  ChatMember[]
  messages Message[]

  pinnedMessages PinnedMessage[]

  invites ChatInvite[]

  stories Story[]

  settings ChatUserSettings[]

  @@index([type])
}

enum ChatType {
  PRIVATE
  GROUP
  CHANNEL
}

//////////////////////////////////////////////////////
// CHAT MEMBERS
//////////////////////////////////////////////////////

model ChatMember {
  id String @id @default(uuid())

  chatId String
  userId String

  role ChatRole @default(MEMBER)

  mutedUntil DateTime?
  isArchived Boolean   @default(false)

  joinedAt DateTime @default(now())

  chat Chat @relation(fields: [chatId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([chatId, userId])
}

enum ChatRole {
  OWNER
  ADMIN
  MODERATOR
  MEMBER
}

//////////////////////////////////////////////////////
// CHAT INVITES
//////////////////////////////////////////////////////

model ChatInvite {
  id String @id @default(uuid())

  chatId String

  code String @unique

  createdBy String

  usageLimit Int?
  usedCount  Int  @default(0)

  expiresAt DateTime?

  createdAt DateTime @default(now())

  chat Chat @relation(fields: [chatId], references: [id])
}

model ChatUserSettings {
  id String @id @default(uuid())

  chatId String
  userId String

  muted    Boolean @default(false)
  archived Boolean @default(false)
  pinned   Boolean @default(false)

  createdAt DateTime @default(now())

  chat Chat @relation(fields: [chatId], references: [id])

  @@unique([chatId, userId])
}

model ChatFolder {
  id     String @id @default(uuid())
  userId String
  name   String

  createdAt DateTime @default(now())

  chats ChatFolderItem[]
}

model ChatFolderItem {
  id       String @id @default(uuid())
  folderId String
  chatId   String

  folder ChatFolder @relation(fields: [folderId], references: [id])

  @@unique([folderId, chatId])
}

//////////////////////////////////////////////////////
// MESSAGE
//////////////////////////////////////////////////////

model Message {
  id String @id @default(uuid())

  chatId String
  userId String

  type MessageType @default(TEXT)

  content String?

  mediaUrl  String?
  mediaType MediaType?

  fileName String?
  fileSize Int?

  latitude  Float?
  longitude Float?

  transactionId     String?
  paymentId         String?
  p2pTransferId     String?
  qrOperationId     String?
  walletOperationId String?

  replyToMessageId String?
  replyToMessage   Message?  @relation("MessageReply", fields: [replyToMessageId], references: [id])
  replies          Message[] @relation("MessageReply")

  forwardedFromMessageId String?
  forwardedFromMessage   Message?  @relation("MessageForward", fields: [forwardedFromMessageId], references: [id])
  forwardedMessages      Message[] @relation("MessageForward")

  reactions MessageReaction[]

  deliveredAt DateTime?
  readAt      DateTime?

  editedAt DateTime?

  deletedAt DateTime?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  chat Chat @relation(fields: [chatId], references: [id])

  transaction     Transaction?     @relation(fields: [transactionId], references: [id])
  payment         Payment?         @relation("MessagePayment", fields: [paymentId], references: [id])
  p2pTransfer     P2PTransfer?     @relation("MessageP2PTransfer", fields: [p2pTransferId], references: [id])
  qrOperation     QrOperation?     @relation("MessageQrOperation", fields: [qrOperationId], references: [id])
  walletOperation WalletOperation? @relation("MessageWalletOperation", fields: [walletOperationId], references: [id])

  @@index([chatId, createdAt])
  @@index([replyToMessageId])
  @@index([transactionId])
  @@index([paymentId])
  @@index([p2pTransferId])
  @@index([qrOperationId])
  @@index([walletOperationId])
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  VOICE
  FILE
  LOCATION
  MONEY
  QR
  PAYMENT_REQUEST
  SYSTEM
}

enum MediaType {
  IMAGE
  VIDEO
  FILE
  VOICE
}

//////////////////////////////////////////////////////
// MESSAGE REACTIONS
//////////////////////////////////////////////////////

model MessageReaction {
  id String @id @default(uuid())

  messageId String
  userId    String

  reaction String

  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([messageId, userId])
}

//////////////////////////////////////////////////////
// PINNED
//////////////////////////////////////////////////////

model PinnedMessage {
  id String @id @default(uuid())

  chatId    String
  messageId String

  pinnedBy String

  createdAt DateTime @default(now())

  chat Chat @relation(fields: [chatId], references: [id])
}

//////////////////////////////////////////////////////
// STORIES
//////////////////////////////////////////////////////

model Story {
  id     String @id @default(uuid())
  userId String

  mediaUrl String?
  text     String?

  createdAt DateTime @default(now())
  expiresAt DateTime

  views  StoryView[]
  User   User        @relation(fields: [userId], references: [id])
  Chat   Chat?       @relation(fields: [chatId], references: [id])
  chatId String?
}

model StoryView {
  id String @id @default(uuid())

  storyId  String
  viewerId String

  viewedAt DateTime @default(now())

  story Story @relation(fields: [storyId], references: [id])

  @@unique([storyId, viewerId])
}

//////////////////////////////////////////////////////
// PRESENCE
//////////////////////////////////////////////////////

model Presence {
  userId String @id

  status PresenceStatus

  lastSeen DateTime

  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

enum PresenceStatus {
  ONLINE
  OFFLINE
}

//////////////////////////////////////////////////////
// MARKETPLACE
//////////////////////////////////////////////////////

model Product {
  id String @id @default(uuid())

  sellerId String

  title       String
  description String?

  price Decimal @db.Decimal(20, 6)

  currency String

  stock Int

  createdAt DateTime @default(now())

  seller    User        @relation(fields: [sellerId], references: [id])
  OrderItem OrderItem[]
}

model Order {
  id String @id @default(uuid())

  buyerId String

  status OrderStatus

  total Decimal @db.Decimal(20, 6)

  createdAt DateTime @default(now())

  buyer User @relation(fields: [buyerId], references: [id])

  items OrderItem[]
}

model OrderItem {
  id String @id @default(uuid())

  orderId   String
  productId String

  quantity Int
  price    Decimal @db.Decimal(20, 6)

  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])
}

enum OrderStatus {
  CREATED
  PAID
  SHIPPED
  COMPLETED
  CANCELLED
}

//////////////////////////////////////////////////////
// AI SYSTEM
//////////////////////////////////////////////////////

model AIConversation {
  id String @id @default(uuid())

  userId String

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  messages AIMessage[]
}

model AIMessage {
  id String @id @default(uuid())

  conversationId String

  role AIRole

  content String

  createdAt DateTime @default(now())

  conversation AIConversation @relation(fields: [conversationId], references: [id])
}

enum AIRole {
  USER
  ASSISTANT
  SYSTEM
}

model AISession {
  id String @id @default(uuid())

  userId           String
  mode             AIRuntimeMode @default(PERSONAL)
  locale           String        @default("ru")
  workspaceEnabled Boolean       @default(false)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  lastActiveAt     DateTime?

  user User @relation(fields: [userId], references: [id])

  @@index([userId, mode])
}

model AIConsent {
  id String @id @default(uuid())

  userId                String  @unique
  allowInternetSearch   Boolean @default(true)
  allowMemoryWrite      Boolean @default(false)
  allowWorkspaceBilling Boolean @default(false)
  allowProfileLearning  Boolean @default(false)
  allowFileRead         Boolean @default(true)
  allowWriteActions     Boolean @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model AIConsentEvent {
  id String @id @default(uuid())

  userId   String
  scope    AIConsentScope
  allowed  Boolean @default(false)
  reason   String
  createdAt DateTime @default(now())
  metadata Json?

  user User @relation(fields: [userId], references: [id])

  @@index([userId, scope])
}

model AIMemoryEntry {
  id String @id @default(uuid())

  userId          String
  key             String
  kind            AIMemoryKind   @default(CUSTOM)
  value           Json
  confirmedByUser Boolean        @default(false)
  source          AIMemorySource @default(USER_SAVED)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId, kind])
}

model AIWorkspaceConnection {
  id String @id @default(uuid())

  userId    String
  kind      AIConnectionKind
  label     String
  enabled   Boolean @default(true)
  config    Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId, kind])
}

model AITask {
  id String @id @default(uuid())

  userId               String
  title                String
  mode                 AIRuntimeMode @default(PERSONAL)
  functionKey          AIFunctionKey
  status               AITaskStatus  @default(DRAFT)
  coinPrice            Int           @default(0)
  requiresConfirmation Boolean       @default(true)
  input                Json?
  output               Json?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId, status])
}

model AIUsageEvent {
  id String @id @default(uuid())

  userId     String
  featureKey String
  coinAmount Int    @default(0)
  status     String @default("preview")
  metadata   Json?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, featureKey])
}

enum AIRuntimeMode {
  PERSONAL
  BUSINESS
  EDUCATION
}

enum AIMemoryKind {
  PREFERENCE
  BUSINESS_CONTEXT
  STUDY_CONTEXT
  CUSTOM
}

enum AIMemorySource {
  ASSISTANT_SUGGESTION
  USER_SAVED
  IMPORTED
}

enum AIConnectionKind {
  WALLET
  BUSINESS_WALLET
  MESSENGER
  NOTIFICATIONS
  PROFILE
  WEB_SEARCH_GATEWAY
  TRANSLATION_GATEWAY
  FILE_STORE
  MEDIA_PLAYER
}

enum AITaskStatus {
  DRAFT
  QUEUED
  WAITING_CONFIRMATION
  COMPLETED
  BLOCKED
  CANCELLED
}

enum AIConsentScope {
  INTERNET_SEARCH
  MEMORY_WRITE
  WORKSPACE_BILLING
  PROFILE_LEARNING
  FILE_READ
  WRITE_ACTION
}

enum AIFunctionKey {
  CHAT
  WEB_SEARCH
  IMAGE_SEARCH
  VIDEO_SEARCH
  MUSIC_SEARCH
  FILE_SEARCH
  STUDY_ASSISTANT
  BUSINESS_ASSISTANT
  TRANSLATION_TEXT
  TRANSLATION_AUDIO
  TRANSLATION_VIDEO
  TRANSLATION_CALL
}

//////////////////////////////////////////////////////
// WALLET
//////////////////////////////////////////////////////

model Wallet {
  id String @id @default(uuid())

  userId String

  type     WalletType
  currency String

  nonce  Int     @default(0)
  locked Boolean @default(false)

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  transactions         Transaction[] @relation("TransactionPrimaryWallet")
  outgoingTransactions Transaction[] @relation("TransactionFromWallet")
  incomingTransactions Transaction[] @relation("TransactionToWallet")

  ledgerEntries LedgerEntry[]

  walletOperations WalletOperation[]

  qrs Qr[]

  qrPayments         QRPayment[] @relation("QrPaymentPayerWallet")
  receivedQrPayments QRPayment[] @relation("QrPaymentReceiverWallet")

  payments Payment[]

  sentP2PTransfers     P2PTransfer[] @relation("P2PTransferFromWallet")
  receivedP2PTransfers P2PTransfer[] @relation("P2PTransferToWallet")

  buyerEscrows  Escrow[] @relation("EscrowBuyerWallet")
  sellerEscrows Escrow[] @relation("EscrowSellerWallet")

  coinDeposits       CoinDeposit[]
  coinCreditRequests CoinCreditRequest[]

  balance WalletBalance?

  @@index([userId])
}

enum WalletType {
  MAIN
  SAVINGS
  BONUS
  MERCHANT
  CRYPTO
  COIN
}

model WalletBalance {
  walletId String @id

  balance Decimal @default(0) @db.Decimal(20, 6)

  updatedAt DateTime @updatedAt

  wallet Wallet @relation(fields: [walletId], references: [id])
}

model BusinessWallet {
  id String @id

  ownerUserId String

  businessId   String  @unique
  businessName String
  displayName  String?

  defaultCurrency     String   @default("USD")
  availableCurrencies String[] @default(["USD"])

  balance           Decimal @default(0) @db.Decimal(20, 6)
  holdBalance       Decimal @default(0) @db.Decimal(20, 6)
  serviceFeePercent Decimal @default(0) @db.Decimal(10, 4)

  isMerchantEnabled Boolean @default(false)
  isBusinessEnabled Boolean @default(true)

  status String @default("pending")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner User @relation("BusinessWalletOwner", fields: [ownerUserId], references: [id])

  merchantWallets    MerchantWallet[]
  outgoingOperations WalletOperation[] @relation("BusinessWalletSender")
  incomingOperations WalletOperation[] @relation("BusinessWalletRecipient")

  @@index([ownerUserId])
}

model MerchantWallet {
  id String @id

  ownerUserId String

  businessWalletId String
  merchantId       String? @unique
  merchantName     String
  displayName      String?

  defaultCurrency     String   @default("USD")
  availableCurrencies String[] @default(["USD"])

  balance              Decimal @default(0) @db.Decimal(20, 6)
  holdBalance          Decimal @default(0) @db.Decimal(20, 6)
  serviceFeePercent    Decimal @default(0) @db.Decimal(10, 4)
  settlementFeePercent Decimal @default(0) @db.Decimal(10, 4)

  isMerchantEnabled   Boolean @default(true)
  isSettlementEnabled Boolean @default(true)

  status String @default("pending")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner          User              @relation("MerchantWalletOwner", fields: [ownerUserId], references: [id])
  businessWallet BusinessWallet    @relation(fields: [businessWalletId], references: [id])
  operations     WalletOperation[]

  @@index([ownerUserId])
  @@index([businessWalletId])
}

model WalletOperation {
  id String @id

  kind   String
  status String @default("completed")

  ownerUserId   String?
  walletId      String
  transactionId String? @unique

  senderBusinessWalletId    String?
  recipientBusinessWalletId String?
  merchantWalletId          String?

  amount    Decimal  @db.Decimal(20, 6)
  feeAmount Decimal  @default(0) @db.Decimal(20, 6)
  netAmount Decimal? @db.Decimal(20, 6)
  currency  String?

  idempotencyKey    String? @unique
  clientOperationId String?
  reference         String? @unique
  metadata          Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner  User?  @relation("WalletOperationOwner", fields: [ownerUserId], references: [id])
  wallet Wallet @relation(fields: [walletId], references: [id])

  transaction Transaction? @relation(fields: [transactionId], references: [id])

  senderBusinessWallet    BusinessWallet? @relation("BusinessWalletSender", fields: [senderBusinessWalletId], references: [id])
  recipientBusinessWallet BusinessWallet? @relation("BusinessWalletRecipient", fields: [recipientBusinessWalletId], references: [id])
  merchantWallet          MerchantWallet? @relation(fields: [merchantWalletId], references: [id])

  messages Message[] @relation("MessageWalletOperation")

  @@index([walletId])
  @@index([ownerUserId])
  @@index([kind, createdAt])
  @@index([transactionId])
}

model CoinDeposit {
  id String @id

  ownerUserId String
  walletId    String

  amount          Decimal @db.Decimal(20, 6)
  termMonths      Int
  apr             Decimal @default(16) @db.Decimal(10, 4)
  accruedInterest Decimal @default(0) @db.Decimal(20, 6)

  status String @default("active")

  startedAt     DateTime  @default(now())
  maturesAt     DateTime
  lastAccruedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner  User   @relation(fields: [ownerUserId], references: [id])
  wallet Wallet @relation(fields: [walletId], references: [id])

  @@index([ownerUserId])
  @@index([walletId])
}

model CoinCreditRequest {
  id String @id

  ownerUserId String
  walletId    String

  amount Decimal @db.Decimal(20, 6)

  status String  @default("requested")
  reason String?

  requestedAt DateTime  @default(now())
  reviewedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner  User   @relation(fields: [ownerUserId], references: [id])
  wallet Wallet @relation(fields: [walletId], references: [id])

  @@index([ownerUserId])
  @@index([walletId])
}

//////////////////////////////////////////////////////
// TRANSACTIONS
//////////////////////////////////////////////////////

model Transaction {
  id String @id @default(uuid())

  walletId String

  fromWalletId String?
  toWalletId   String?

  qrId String?

  reference String? @unique

  amount Decimal @db.Decimal(20, 6)

  type   TransactionType
  status TransactionStatus

  createdAt DateTime @default(now())

  wallet     Wallet  @relation("TransactionPrimaryWallet", fields: [walletId], references: [id])
  fromWallet Wallet? @relation("TransactionFromWallet", fields: [fromWalletId], references: [id])
  toWallet   Wallet? @relation("TransactionToWallet", fields: [toWalletId], references: [id])

  qr Qr? @relation(fields: [qrId], references: [id])

  ledgerEntries LedgerEntry[]

  payment         Payment?
  qrPayment       QRPayment?
  qrOperations    QrOperation[]
  p2pTransfer     P2PTransfer?
  escrow          Escrow?
  walletOperation WalletOperation?
  messages        Message[]

  @@index([walletId])
  @@index([fromWalletId])
  @@index([toWalletId])
  @@index([reference])
}

enum TransactionType {
  DEPOSIT
  WITHDRAW
  TRANSFER
  PAYMENT
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

//////////////////////////////////////////////////////
// LEDGER
//////////////////////////////////////////////////////

model LedgerEntry {
  id String @id @default(uuid())

  walletId      String
  transactionId String

  amount Decimal @db.Decimal(20, 6)

  type LedgerEntryType

  operationType LedgerOperationType

  uniqueOperationId String @unique

  createdAt DateTime @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id])

  transaction Transaction @relation(fields: [transactionId], references: [id])

  @@index([walletId])
  @@index([transactionId])
}

enum LedgerEntryType {
  DEBIT
  CREDIT
}

enum LedgerOperationType {
  TRANSFER
  QR_PAYMENT
  DEPOSIT
  WITHDRAW
  MARKETPLACE
  ESCROW_LOCK
  ESCROW_RELEASE
  ESCROW_REFUND
}

//////////////////////////////////////////////////////
// QR SYSTEM
//////////////////////////////////////////////////////

model Qr {
  id String @id @default(uuid())

  ownerUserId String?
  walletId    String?

  type QRType

  rail        String  @default("sabi_core")
  domain      String  @default("payment")
  payloadType String  @default("merchant_payment")
  route       String?

  payload String

  amount Decimal? @db.Decimal(20, 6)

  currency String?

  provider String?

  reference String?
  issuer    String?
  signature String?
  metadata  Json?

  status QRStatus @default(ACTIVE)

  usedCount Int @default(0)

  usageLimit Int?

  expiresAt DateTime?

  createdAt DateTime @default(now())

  ownerUser User?   @relation(fields: [ownerUserId], references: [id])
  wallet    Wallet? @relation(fields: [walletId], references: [id])

  payments   QRPayment[]
  operations QrOperation[]

  transactions Transaction[]

  @@index([ownerUserId])
  @@index([walletId])
  @@index([rail, domain, payloadType])
  @@index([reference])
}

enum QRType {
  STATIC
  DYNAMIC
}

enum QRStatus {
  ACTIVE
  EXPIRED
  DISABLED
}

//////////////////////////////////////////////////////
// QR PAYMENTS
//////////////////////////////////////////////////////

model QRPayment {
  id String @id @default(uuid())

  qrId             String
  payerWalletId    String
  receiverWalletId String?
  transactionId    String? @unique

  amount Decimal @db.Decimal(20, 6)

  currency String

  status PaymentStatus

  route          String?
  failureReason  String?
  idempotencyKey String? @unique
  actorUserId    String?

  createdAt DateTime @default(now())

  qr Qr @relation(fields: [qrId], references: [id])

  payerWallet    Wallet  @relation("QrPaymentPayerWallet", fields: [payerWalletId], references: [id])
  receiverWallet Wallet? @relation("QrPaymentReceiverWallet", fields: [receiverWalletId], references: [id])

  transaction Transaction? @relation(fields: [transactionId], references: [id])

  operations QrOperation[]

  @@index([payerWalletId])
  @@index([receiverWalletId])
  @@index([transactionId])
}

model QrOperation {
  id String @id @default(uuid())

  qrId      String?
  paymentId String?

  rail        String
  domain      String?
  payloadType String
  route       String

  actorUserId      String?
  payerWalletId    String?
  receiverWalletId String?

  amount   Decimal? @db.Decimal(20, 6)
  currency String?

  status         String
  failureReason  String?
  idempotencyKey String? @unique
  reference      String? @unique
  transactionId  String?
  metadata       Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  qr      Qr?        @relation(fields: [qrId], references: [id])
  payment QRPayment? @relation(fields: [paymentId], references: [id])

  transaction Transaction? @relation(fields: [transactionId], references: [id])

  messages Message[] @relation("MessageQrOperation")

  @@index([rail, route])
  @@index([reference])
  @@index([transactionId])
}

//////////////////////////////////////////////////////
// PAYMENTS
//////////////////////////////////////////////////////

model PaymentAudit {
  id String @id @default(uuid())

