{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "core/events/*": ["src/core/events/*", "src/core/events.disabled/*"],
      "core/*": ["src/core/*"],
      "modules/*": ["src/modules/*"]
    },
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true
  },
  "include": [
    "src/app.ts",
    "src/server.ts",
    "src/modules/admin/**/*.ts",
    "src/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    ".data",
    "admin-ui",
    "src/**/*.tsx",
    "src/core/realtime/realtime.gateway.ts",
    "src/core/realtime/websocket.gateway.ts",
    "src/core/gateway/ws.gateway.ts"
  ]
}