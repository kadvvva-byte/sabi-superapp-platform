# Keep real project/source files visible to Git:
# - android/ and ios/ are NOT ignored
# - modules/**/android and modules/**/ios are NOT ignored
# - .txt, .md, .ps1, .cjs are NOT globally ignored

# Local/generated folders - do not commit
android/
ios/
backend/
public/
docs/
tools/
scripts/
patches/
.vscode/

# Local repair / backup files
*.bak
*.bak-*
*.log
README.md
README_*.txt
REMOVED_FILES_MANIFEST.txt
SABI_REPAIR_README_RU.txt
src/README.txt
src/modules/**/README.md
src/modules/**/README.txt
