{
  "expo": {
    "name": "superapp-mobile",
    "slug": "superapp-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "superappmobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.sabiai.superapp",
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MICROPHONE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.READ_PHONE_STATE",
        "android.permission.CALL_PHONE",
        "android.permission.BIND_TELECOM_CONNECTION_SERVICE",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.WAKE_LOCK",
        "android.permission.VIBRATE",
        "android.permission.USE_FULL_SCREEN_INTENT",
        "android.permission.FOREGROUND_SERVICE_PHONE_CALL",
        "android.permission.MANAGE_OWN_CALLS"
      ],
      "package": "app.sabiai.superapp",
      "usesCleartextTraffic": true,
      "googleServicesFile": "./google-services.json",
      "versionCode": 1
    },
    "web": {
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "sounds": [
            "./assets/sounds/sabi_call_neon.wav",
            "./assets/sounds/sabi_call_premium.wav",
            "./assets/sounds/sabi_call_soft.wav",
            "./assets/sounds/sabi_call_digital.wav",
            "./assets/sounds/sabi_call_skyline.wav",
            "./assets/sounds/sabi_call_ocean.wav",
            "./assets/sounds/sabi_call_crystal.wav",
            "./assets/sounds/sabi_call_lux.wav",
            "./assets/sounds/sabi_call_night.wav",
            "./assets/sounds/sabi_call_minimal.wav",
            "./assets/sounds/sabi_msg_clean.wav",
            "./assets/sounds/sabi_msg_soft.wav",
            "./assets/sounds/sabi_msg_glass.wav",
            "./assets/sounds/sabi_msg_pop.wav",
            "./assets/sounds/sabi_msg_air.wav",
            "./assets/sounds/sabi_msg_pixel.wav",
            "./assets/sounds/sabi_msg_drop.wav",
            "./assets/sounds/sabi_msg_bell.wav",
            "./assets/sounds/sabi_msg_swipe.wav",
            "./assets/sounds/sabi_msg_tap.wav",
            "./assets/sounds/sabi_wallet_confirm.wav",
            "./assets/sounds/sabi_wallet_alert.wav",
            "./assets/sounds/sabi_market_alert.wav",
            "./assets/sounds/sabi_market_soft.wav",
            "./assets/sounds/sabi_ai_ping.wav",
            "./assets/sounds/sabi_ai_soft.wav",
            "./assets/sounds/sabi_system_notice.wav",
            "./assets/sounds/sabi_system_soft.wav"
          ]
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow Sabi to use Face ID to confirm payments and transfers."
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Allow Sabi to use the microphone for voice messages, calls, live audio, and streams.",
          "enableBackgroundRecording": true,
          "enableBackgroundPlayback": true
        }
      ],
      [
        "@config-plugins/react-native-webrtc",
        {
          "cameraPermission": "Allow Sabi to use the camera for video calls, live streams, and media capture.",
          "microphonePermission": "Allow Sabi to use the microphone for voice messages, calls, live audio, and streams."
        }
      ],
      [
        "@config-plugins/react-native-callkeep",
        {
          "ios": {
            "appName": "Sabi",
            "supportsVideo": false,
            "includesCallsInRecents": true,
            "maximumCallGroups": 1,
            "maximumCallsPerCallGroup": 1
          }
        }
      ],
      "./modules/sabi-screen-share/app.plugin.js",
      "./modules/sabi-video-call-picture-in-picture/app.plugin.js",
      "expo-web-browser",
      "expo-asset",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true,
            "compileSdkVersion": 36,
            "targetSdkVersion": 36,
            "minSdkVersion": 24
          }
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Sabi to use your location to share your location in Messenger and nearby features."
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      "@react-native-firebase/messaging"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4b42bed1-e971-4b94-8007-d6b18ac750ca"
      },
      "apiBaseUrl": "",
      "authApiBaseUrl": "",
      "qrApiBaseUrl": "",
      "socketBaseUrl": "",
      "socketPath": "/socket.io"
    },
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    }
  }
}